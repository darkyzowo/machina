{
  "_readme": [
    "Machina v3.1 settings template — merged into ~/.claude/settings.json by migrate-v3.sh",
    "Windows: paths use forward slashes in hook commands",
    "Set MACHINA_KEEP_STATUSLINE=1 to preserve claude-hud during migration"
  ],

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/harness-init.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/secret-guard.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/phase-gate.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/pass-ceiling.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/verifier-capture.js\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/verifier-capture.js\"",
            "timeout": 15
          }
        ]
      }
    ]
  },

  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline.sh\""
  }
}
