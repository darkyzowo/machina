{
  "_readme": [
    "Machina v3 settings template — copy blocks into ~/.claude/settings.json.",
    "Windows (Git Bash): replace $HOME with C:/Users/YOUR_USERNAME",
    "Caveman / claude-hud / claude-mem are optional add-ons — not Machina defaults.",
    "Profile tools: bash scripts/profile-setup.sh (after make profile)"
  ],

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/harness-init.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/secret-guard.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/phase-gate.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/pass-ceiling.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/verifier-capture.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  },

  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline.sh\""
  },

  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true
  },

  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    }
  }
}
