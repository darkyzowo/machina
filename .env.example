# .env.example — copy to .env and fill in relevant values.
# .env is gitignored. Only variables relevant to your active profile matter.
# Run `make profile` to see or change your profile.

# ── All profiles ──────────────────────────────────────────────────────────────
# Anthropic API key — only needed if running via API (not Claude Pro/Team/Enterprise).
# ANTHROPIC_API_KEY=sk-ant-...

# ── standard+ profile ─────────────────────────────────────────────────────────
# CAVEMAN_LEVEL=full
# CAVEMAN_STATUSLINE_SAVINGS=1

# ── full profile ──────────────────────────────────────────────────────────────
# CLAUDE_MEM_PROVIDER=claude
# CLAUDE_MEM_MODE=code
# CLAUDE_MEM_PORT=37777
# GRAPHIFY_MODE=standard
