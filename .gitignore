# ── Agent memory and graph artifacts (must not commit) ───────────────────────
# graphify output: graph.json, html, cache
graphify-out/
# graphify python env pointer
**/.graphify_python
# SQLite episodic memory stores
*.db
# ChromaDB vector stores
**/chroma/
**/chromadb/
# claude-mem local data
.claude-mem/
# local profile state — regenerate with: make profile
.agent-profile
# cursor phase state + pass counters — regenerate with: make bootstrap
.machina/

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets.*
reports/               # config audit reports may contain local path info

# ── Dependencies and build output ─────────────────────────────────────────────
node_modules/
.venv/
__pycache__/
*.pyc
*.pyo
dist/
build/
.cache/
.turbo/
.next/
out/

# ── Editor and OS noise ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.code-workspace
